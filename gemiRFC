    // --- 유틸리티 메서드 ---
    private static void createDestinationFile(String name, Properties props) throws IOException {
        File f = new File(name + ".jcoDestination");
        try (FileOutputStream fos = new FileOutputStream(f)) {
            props.store(fos, "SAP Audit Config");
        }
    }

    private static void writeCsv(String fileName, List<String[]> rows) throws IOException {
        try (BufferedWriter bw = new BufferedWriter(new OutputStreamWriter(new FileOutputStream(fileName), StandardCharsets.UTF_8))) {
            for (String[] row : rows) {
                StringBuilder line = new StringBuilder();
                for (int i = 0; i < row.length; i++) {
                    if (i > 0) line.append(",");
                    line.append("\"").append(row[i].replace("\"", "\"\"")).append("\"");
                }
                bw.write(line.toString());
                bw.newLine();
            }
        }
    }

    private static String summarizeParams(JCoParameterList list) {
        if (list == null) return "-";
        JCoListMetaData meta = list.getMetaData();
        StringBuilder sb = new StringBuilder();
        int limit = Math.min(meta.getFieldCount(), PARAM_PREVIEW_LIMIT);
        for (int i = 0; i < limit; i++) {
            if (i > 0) sb.append("|");
            sb.append(meta.getName(i));
        }
        return sb.toString();
    }

    private static void addCategory(LinkedHashMap<String, LinkedHashSet<String>> map, String cat, String... rfcs) {
        map.putIfAbsent(cat, new LinkedHashSet<>());
        for (String r : rfcs) if (r != null) map.get(cat).add(r.trim());
    }

    private static String sanitize(String s) { return s == null ? "" : s.replace("\n", " ").replace("\r", ""); }
    private static String safe(String s) { return s == null ? "" : s; }
}
