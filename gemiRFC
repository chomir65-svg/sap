/**
 * SAP RFC Callable Evidence Mega Audit (High-Volume Edition)
 * 목표: 500개 이상의 RFC/BAPI 카탈로그 점검 및 실제 데이터 추출 증거 수집
 */
public class SapRfcCallableEvidenceMegaAudit {
    private static final String DEST_NAME = "SAP_CALLABLE_EVIDENCE_DEST";
    private static final int PARAM_PREVIEW_LIMIT = 12;

    enum ProbeResultType {
        METADATA_ONLY,
        DENIED_RFC_AUTH,
        CALL_REACHED_BACKEND,
        COMM_OR_SYSTEM_ERROR,
        NOT_FOUND,
        ERROR
    }

    // 보고서에서 강조할 고위험/고가치 RFC 리스트
    private static final Set<String> HIGH_VALUE_RFC = new LinkedHashSet<>(Arrays.asList(
        "RFC_READ_TABLE", "BBP_RFC_READ_TABLE", "DSY_READ_TABLE", "RFC_GET_TABLE_ENTRIES",
        "RZL_READ_FILE_LOCAL", "RZL_WRITE_FILE_LOCAL", "RZL_READ_DIR_LOCAL", "EPS_GET_DIRECTORY_LISTING",
        "TH_USER_LIST", "TH_USER_INFO", "TH_DELETE_USER",
        "BAPI_USER_GET_DETAIL", "BAPI_USER_CREATE", "BAPI_USER_CHANGE", "BAPI_USER_UNLOCK", "SUSR_LOGIN_CHECK_RFC",
        "RFC_SYSTEM_INFO", "SXPG_COMMAND_EXECUTE", "SXPG_CALL_SYSTEM", "RFC_REMOTE_EXEC",
        "RFC_ABAP_INSTALL_AND_RUN", "RS_STP_COMMAND_EXECUTE", "BP_JOB_SELECT", "BP_JOB_DELETE"
    ));

    // 실제 execute()를 수행하여 증거를 수집할 안전한 조회성 RFC 리스트
    private static final Set<String> EXECUTE_PROBE_ALLOWLIST = new LinkedHashSet<>(Arrays.asList(
        "RFC_PING", "STFC_CONNECTION", "RFC_SYSTEM_INFO", "RFC_TRUSTED_CHECK", "RFC_GET_LOCAL_DEST_NAMES",
        "RFC_READ_TABLE", "BBP_RFC_READ_TABLE", 
        "TH_USER_LIST", "TH_SERVER_LIST", "BAPI_USER_GET_DETAIL", "BAPI_COMPANYCODE_GETLIST",
        "BAPI_EMPLOYEE_GETDATA", "EPS_GET_DIRECTORY_LISTING"
    ));

    public static void main(String[] args) {
        Properties props = new Properties();

        // [주의] 현장 환경에 맞게 수정하십시오.
        props.setProperty("jco.client.ashost", "SAP_IP");
        props.setProperty("jco.client.sysnr",  "00");
        props.setProperty("jco.client.client", "100");
        props.setProperty("jco.client.user",   "USER_ID");
        props.setProperty("jco.client.passwd", "PASSWORD");
        props.setProperty("jco.client.lang",   "KO");

        try {
            createDestinationFile(DEST_NAME, props);

            JCoDestination dest = JCoDestinationManager.getDestination(DEST_NAME);
            JCoRepository repo = dest.getRepository();
            JCoAttributes attr = dest.getAttributes();

            LinkedHashMap<String, LinkedHashSet<String>> categoryMap = buildTargetCatalog();

            List<String[]> rows = new ArrayList<>();
            // CSV 헤더
            rows.add(new String[]{
                "CATEGORY", "RFC_NAME", "REPO_VISIBLE", "PROBE_ATTEMPTED",
                "PROBE_RESULT", "HIGHLIGHT", "EVIDENCE_LEVEL", "JCO_GROUP",
                "MESSAGE", "INTERPRETATION", "EVIDENCE_DATA",
                "IMPORT_PARAMS", "EXPORT_PARAMS", "TABLE_PARAMS"
            });

            int total = 0, repoVisibleCount = 0, callableCount = 0, highValueCallableCount = 0;

            System.out.println("==================================================================");
            System.out.println("        [SAP RFC CALLABLE EVIDENCE MEGA AUDIT - ACTIVE MODE]");
            System.out.println("==================================================================");
            System.out.println("System ID : " + safe(attr.getSystemID()));
            System.out.println("Host      : " + safe(attr.getHost()));
            System.out.println("User      : " + safe(attr.getUser()));
            System.out.println("Probe Mode: ACTIVE (Payload Injection & Data Extraction)");
            System.out.println("==================================================================");

            for (Map.Entry<String, LinkedHashSet<String>> entry : categoryMap.entrySet()) {
                String category = entry.getKey();
                LinkedHashSet<String> rfcs = entry.getValue();

                System.out.println("\n[CATEGORY] " + category + " (Targets: " + rfcs.size() + ")");

                for (String rfcName : rfcs) {
                    total++;
                    String[] row = inspectCallableEvidence(dest, repo, category, rfcName);
                    rows.add(row);

                    if ("Y".equals(row[2])) repoVisibleCount++;
                    if ("CALLABLE".equals(row[5]) || "HIGH_VALUE_CALLABLE".equals(row[5])) callableCount++;
                    if ("HIGH_VALUE_CALLABLE".equals(row[5])) highValueCallableCount++;
                }
            }

            writeCsv("sap_rfc_mega_audit_report.csv", rows);

            System.out.println("\n==================================================================");
            System.out.println("[FINAL SUMMARY]");
            System.out.println("Total Targets Scanned        : " + total);
            System.out.println("Repository Visible RFCs      : " + repoVisibleCount);
            System.out.println("Execution Potential Confirmed: " + callableCount);
            System.out.println("High-Value Evidence Extracted: " + highValueCallableCount);
            System.out.println("Report Saved To              : sap_rfc_mega_audit_report.csv");
            System.out.println("==================================================================");

        } catch (Exception e) {
            System.err.println("[!] Audit Failed: " + sanitize(e.getMessage()));
        }
    }

    private static String[] inspectCallableEvidence(JCoDestination dest, JCoRepository repo, String category, String rfcName) {
        String repoVisible = "N", probeAttempted = "N", probeResult = ProbeResultType.NOT_FOUND.name();
        String highlight = "NONE", evidenceLevel = "LOW", jcoGroup = "", message = "", interpretation = "", evidenceData = "NO_DATA";
        String imports = "", exports = "", tables = "";

        try {
            JCoFunction func = repo.getFunction(rfcName);
            if (func == null) {
                interpretation = "Repository lookup returned null";
                return new String[]{category, rfcName, repoVisible, probeAttempted, probeResult, highlight, evidenceLevel, jcoGroup, interpretation, interpretation, evidenceData, imports, exports, tables};
            }

            repoVisible = "Y";
            imports = summarizeParams(func.getImportParameterList());
            exports = summarizeParams(func.getExportParameterList());
            tables = summarizeParams(func.getTableParameterList());

            if (EXECUTE_PROBE_ALLOWLIST.contains(rfcName)) {
                probeAttempted = "Y";
                try {
                    injectPayload(func, rfcName);
                    func.execute(dest);
                    probeResult = ProbeResultType.CALL_REACHED_BACKEND.name();
                    message = "Execution successful";
                    evidenceData = extractEvidence(func, rfcName);
                } catch (JCoException e) {
                    jcoGroup = String.valueOf(e.getGroup());
                    message = sanitize(e.getMessage());
                    probeResult = classifyProbeResult(e, rfcName).name();
                }
            } else {
                probeResult = ProbeResultType.METADATA_ONLY.name();
                message = "Skipped by probe policy";
            }

            highlight = decideHighlight(rfcName, repoVisible, probeResult, evidenceData);
            evidenceLevel = decideEvidenceLevel(highlight);
            interpretation = buildInterpretation(repoVisible, probeAttempted, probeResult);

            printSummaryLine(rfcName, highlight, evidenceData);

            return new String[]{category, rfcName, repoVisible, probeAttempted, probeResult, highlight, evidenceLevel, jcoGroup, message, interpretation, evidenceData, imports, exports, tables};

        } catch (Exception e) {
            return new String[]{category, rfcName, "Y", "N", "ERROR", "ERROR", "LOW", "", sanitize(e.getMessage()), "Internal Audit Error", "NO_DATA", "", "", ""};
        }
    }

    private static void injectPayload(JCoFunction func, String rfcName) {
        try {
            if (rfcName.contains("READ_TABLE")) {
                func.getImportParameterList().setValue("QUERY_TABLE", "USR02");
                func.getImportParameterList().setValue("ROWCOUNT", 1);
            } else if ("STFC_CONNECTION".equals(rfcName)) {
                func.getImportParameterList().setValue("REQUTEXT", "EVIDENCE_PROBE");
            }
        } catch (Exception ignored) {}
    }

    private static String extractEvidence(JCoFunction func, String rfcName) {
        try {
            if ("RFC_SYSTEM_INFO".equals(rfcName)) {
                JCoStructure si = func.getExportParameterList().getStructure("RFCSI_EXPORT");
                return String.format("OS:%s, DB:%s, Release:%s", si.getString("RFCOPSYS"), si.getString("RFCDBHOST"), si.getString("RFCSYSREL"));
            }
            if (rfcName.contains("READ_TABLE")) {
                JCoTable data = func.getTableParameterList().getTable("DATA");
                return data.getNumRows() > 0 ? "Table Data Sample Found" : "Empty Table";
            }
            if ("TH_USER_LIST".equals(rfcName)) {
                return "Active Users: " + func.getTableParameterList().getTable("USRLIST").getNumRows();
            }
        } catch (Exception e) { return "PARSE_ERROR"; }
        return "SUCCESS_NO_DATA";
    }

    private static ProbeResultType classifyProbeResult(JCoException e, String rfcName) {
        String msg = e.getMessage().toLowerCase();
        if (msg.contains("authorization") || msg.contains("not authorized")) return ProbeResultType.DENIED_RFC_AUTH;
        if (msg.contains("required") || msg.contains("query_table")) return ProbeResultType.CALL_REACHED_BACKEND;
        return ProbeResultType.ERROR;
    }

    private static String decideHighlight(String rfcName, String repoVisible, String probeResult, String evidence) {
        if (!"NO_DATA".equals(evidence) && !"SUCCESS_NO_DATA".equals(evidence)) return "HIGH_VALUE_CALLABLE";
        if (ProbeResultType.CALL_REACHED_BACKEND.name().equals(probeResult)) return "CALLABLE";
        if ("Y".equals(repoVisible)) return "EXPOSED_METADATA";
        return "NONE";
    }

    private static String decideEvidenceLevel(String highlight) {
        if (highlight.contains("HIGH_VALUE")) return "HIGH";
        if (highlight.equals("CALLABLE")) return "MEDIUM";
        return "LOW";
    }

    private static String buildInterpretation(String repoVisible, String probeAttempted, String probeResult) {
        if (!"Y".equals(repoVisible)) return "접근 불가";
        if (ProbeResultType.CALL_REACHED_BACKEND.name().equals(probeResult)) return "백엔드 호출 성공 (권한 과다)";
        if (ProbeResultType.DENIED_RFC_AUTH.name().equals(probeResult)) return "권한에 의해 차단됨";
        return "조회만 가능";
    }

    private static void printSummaryLine(String rfcName, String highlight, String evidence) {
        String tag = highlight.equals("HIGH_VALUE_CALLABLE") ? "[!!!]" : highlight.equals("CALLABLE") ? "[ + ]" : "[   ]";
        System.out.printf("%s %-30s -> %s\n", tag, rfcName, highlight);
    }

