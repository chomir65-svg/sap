    public static void main(String[] args) {
        Properties props = new Properties();

        // 현장 정보로 수정
        props.setProperty("jco.client.ashost", "SAP_IP");
        props.setProperty("jco.client.sysnr",  "00");
        props.setProperty("jco.client.client", "100");
        props.setProperty("jco.client.user",   "USER_ID");
        props.setProperty("jco.client.passwd", "PASSWORD");
        props.setProperty("jco.client.lang",   "KO");

        try {
            createDestinationFile(DEST_NAME, props);

            JCoDestination dest = JCoDestinationManager.getDestination(DEST_NAME);
            JCoRepository repo = dest.getRepository();
            JCoAttributes attr = dest.getAttributes();

            LinkedHashMap<String, LinkedHashSet<String>> categoryMap = buildTargetCatalog();
            loadExternalTargets(categoryMap, EXTRA_TARGET_FILE);

            List<String[]> rows = new ArrayList<>();
            rows.add(new String[]{
                "CATEGORY",
                "RFC_NAME",
                "REPO_VISIBLE",
                "PROBE_ATTEMPTED",
                "PROBE_RESULT",
                "HIGHLIGHT",
                "EVIDENCE_LEVEL",
                "JCO_GROUP",
                "MESSAGE",
                "INTERPRETATION",
                "IMPORT_PARAMS",
                "EXPORT_PARAMS",
                "TABLE_PARAMS"
            });

            int total = 0;
            int repoVisibleCount = 0;
            int callableCount = 0;
            int highValueCallableCount = 0;

            System.out.println("==================================================================");
            System.out.println("        [SAP RFC CALLABLE EVIDENCE MEGA AUDIT - SAFE MODE]");
            System.out.println("==================================================================");
            System.out.println("System ID : " + safe(attr.getSystemID()));
            System.out.println("Client    : " + safe(attr.getClient()));
            System.out.println("User      : " + safe(attr.getUser()));
            System.out.println("Host      : " + safe(attr.getHost()));
            System.out.println("Start Time: " + new java.util.Date());
            System.out.println("Probe Mode: allowlist only / no payload injection");
            System.out.println("==================================================================");

            for (Map.Entry<String, LinkedHashSet<String>> entry : categoryMap.entrySet()) {
                String category = entry.getKey();
                LinkedHashSet<String> rfcs = entry.getValue();

                System.out.println();
                System.out.println("==================================================");
                System.out.println("[CATEGORY] " + category + " / count=" + rfcs.size());
                System.out.println("==================================================");

                for (String rfcName : rfcs) {
                    total++;
                    String[] row = inspectCallableEvidence(dest, repo, category, rfcName);
                    rows.add(row);

                    if ("Y".equals(row[2])) repoVisibleCount++;
                    if ("CALLABLE".equals(row[5]) || "HIGH_VALUE_CALLABLE".equals(row[5])) callableCount++;
                    if ("HIGH_VALUE_CALLABLE".equals(row[5])) highValueCallableCount++;
                }
            }

            writeCsv("sap_rfc_callable_evidence_mega_report.csv", rows);

            System.out.println();
            System.out.println("==================================================================");
            System.out.println("[FINAL SUMMARY]");
            System.out.println("총 점검 RFC 수              : " + total);
            System.out.println("리포지토리 노출 RFC 수      : " + repoVisibleCount);
            System.out.println("호출 가능성 확인 RFC 수      : " + callableCount);
            System.out.println("고가치 호출 가능 RFC 수      : " + highValueCallableCount);
            System.out.println("추가 목록 파일              : " + EXTRA_TARGET_FILE);
            System.out.println("CSV                         : sap_rfc_callable_evidence_mega_report.csv");
            System.out.println("==================================================================");

        } catch (Exception e) {
            System.err.println("[!] 점검 실패: " + sanitize(e.getMessage()));
            e.printStackTrace();
        }
    }

