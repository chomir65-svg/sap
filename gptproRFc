    private static String[] inspectCallableEvidence(JCoDestination dest, JCoRepository repo, String category, String rfcName) {
        String repoVisible = "N";
        String probeAttempted = "N";
        String probeResult = ProbeResultType.NOT_FOUND.name();
        String highlight = "NONE";
        String evidenceLevel = "LOW";
        String jcoGroup = "";
        String message = "";
        String interpretation = "";
        String imports = "";
        String exports = "";
        String tables = "";

        try {
            JCoFunction func = repo.getFunction(rfcName);
            if (func == null) {
                interpretation = "Repository lookup returned null";
                printLine(rfcName, highlight, interpretation);
                return new String[]{
                    category, rfcName, repoVisible, probeAttempted, probeResult, highlight,
                    evidenceLevel, jcoGroup, interpretation, interpretation, imports, exports, tables
                };
            }

            repoVisible = "Y";
            imports = summarizeParams(func.getImportParameterList());
            exports = summarizeParams(func.getExportParameterList());
            tables = summarizeParams(func.getTableParameterList());

            if (EXECUTE_PROBE_ALLOWLIST.contains(rfcName)) {
                probeAttempted = "Y";
                try {
                    // 중요:
                    // - 민감 파라미터 주입 금지
                    // - 실제 데이터 조회 값 세팅 금지
                    // - 단순 execute 후 권한 거부인지 아닌지만 판정
                    func.execute(dest);
                    probeResult = ProbeResultType.CALL_REACHED_BACKEND.name();
                    message = "Execution completed without RFC authorization failure";
                } catch (JCoException e) {
                    jcoGroup = String.valueOf(e.getGroup());
                    message = sanitize(e.getMessage());
                    probeResult = classifyProbeResult(e, rfcName).name();
                }
            } else {
                probeAttempted = "N";
                probeResult = ProbeResultType.METADATA_ONLY.name();
                message = "Probe skipped by safe allowlist policy";
            }

            highlight = decideHighlight(rfcName, repoVisible, probeResult, message);
            evidenceLevel = decideEvidenceLevel(highlight);
            interpretation = buildInterpretation(rfcName, repoVisible, probeAttempted, probeResult, message);

            printHighlighted(rfcName, repoVisible, probeAttempted, probeResult, highlight, interpretation, message);

            return new String[]{
                category, rfcName, repoVisible, probeAttempted, probeResult, highlight,
                evidenceLevel, jcoGroup, message, interpretation, imports, exports, tables
            };

        } catch (JCoException e) {
            jcoGroup = String.valueOf(e.getGroup());
            message = sanitize(e.getMessage());
            probeResult = ProbeResultType.ERROR.name();
            interpretation = "JCo exception during repository/probe stage";
            printLine(rfcName, "ERROR", interpretation);
            return new String[]{
                category, rfcName, repoVisible, probeAttempted, probeResult, "ERROR",
                "LOW", jcoGroup, message, interpretation, imports, exports, tables
            };

        } catch (Exception e) {
            message = sanitize(e.getMessage());
            probeResult = ProbeResultType.ERROR.name();
            interpretation = "Unexpected error during probe stage";
            printLine(rfcName, "ERROR", interpretation);
            return new String[]{
                category, rfcName, repoVisible, probeAttempted, probeResult, "ERROR",
                "LOW", jcoGroup, message, interpretation, imports, exports, tables
            };
        }
    }

    private static ProbeResultType classifyProbeResult(JCoException e, String rfcName) {
        String msg = sanitize(e.getMessage()).toLowerCase(Locale.ROOT);

        if (msg.contains("no rfc authorization") || msg.contains("not authorized")) {
            return ProbeResultType.DENIED_RFC_AUTH;
        }

        if (containsAny(msg,
                "required", "missing", "empty", "invalid",
                "not found", "does not exist",
                "query_table", "rowcount", "delimiter", "field", "table",
                "screen output without connection to user")) {
            return ProbeResultType.CALL_REACHED_BACKEND;
        }

        if (e.getGroup() == JCoException.JCO_ERROR_COMMUNICATION
                || e.getGroup() == JCoException.JCO_ERROR_SYSTEM_FAILURE
                || e.getGroup() == JCoException.JCO_ERROR_LOGON_FAILURE) {
            return ProbeResultType.COMM_OR_SYSTEM_ERROR;
        }

        return ProbeResultType.ERROR;
    }

    private static String decideHighlight(String rfcName, String repoVisible, String probeResult, String message) {
        boolean isHighValue = HIGH_VALUE_RFC.contains(rfcName);
        boolean repoExposed = "Y".equals(repoVisible);
        boolean backendReached = ProbeResultType.CALL_REACHED_BACKEND.name().equals(probeResult);
        boolean denied = ProbeResultType.DENIED_RFC_AUTH.name().equals(probeResult);

        if (repoExposed && isHighValue && backendReached) {
            return "HIGH_VALUE_CALLABLE";
        }

        if (repoExposed && isHighValue && !denied &&
            message != null &&
            containsAny(message.toLowerCase(Locale.ROOT),
                "required", "missing", "invalid", "not found", "does not exist",
                "query_table", "rowcount", "delimiter", "field", "table")) {
            return "HIGH_VALUE_CALLABLE";
        }

        if (repoExposed && backendReached) {
            return "CALLABLE";
        }

        if (repoExposed && denied) {
            return "EXPOSED_BUT_DENIED";
        }

        if (repoExposed) {
            return "REPO_ONLY";
        }

        return "NONE";
    }

    private static String decideEvidenceLevel(String highlight) {
        switch (highlight) {
            case "HIGH_VALUE_CALLABLE":
                return "HIGH";
            case "CALLABLE":
                return "MEDIUM";
            case "EXPOSED_BUT_DENIED":
                return "MEDIUM";
            case "REPO_ONLY":
                return "LOW";
            default:
                return "LOW";
        }
    }

    private static String buildInterpretation(String rfcName, String repoVisible, String probeAttempted,
                                              String probeResult, String message) {
        String msg = message == null ? "" : message.toLowerCase(Locale.ROOT);

        if (!"Y".equals(repoVisible)) {
            return "저장소에서 함수 메타데이터가 확인되지 않음";
        }

        if ("N".equals(probeAttempted)) {
            return "메타데이터 노출 확인 - 안전 정책상 실행 probe 생략";
        }

        if (ProbeResultType.DENIED_RFC_AUTH.name().equals(probeResult)) {
            return "메타데이터는 노출되나 RFC 실행 권한은 거부됨";
        }

        if ("RFC_READ_TABLE".equals(rfcName) || "BBP_RFC_READ_TABLE".equals(rfcName) || "DSY_READ_TABLE".equals(rfcName)) {
            if (containsAny(msg, "query_table", "rowcount", "delimiter", "field", "required", "missing", "invalid")) {
                return "권한 거부가 아닌 인터페이스/입력 검증 응답 확인 - 테이블 조회 RFC 호출 단계 진입 가능";
            }
        }

        if ("RZL_READ_FILE_LOCAL".equals(rfcName) || "RZL_WRITE_FILE_LOCAL".equals(rfcName)
                || "EPS_GET_DIRECTORY_LISTING".equals(rfcName)) {
            if (containsAny(msg, "required", "missing", "invalid", "not found", "does not exist")) {
                return "권한 거부가 아닌 파일 처리 단계 응답 확인 - 파일 계열 RFC 호출 가능성 높음";
            }
        }

        if ("BAPI_USER_GET_DETAIL".equals(rfcName) || "TH_USER_LIST".equals(rfcName) || "TH_USER_INFO".equals(rfcName)) {
            if (containsAny(msg, "required", "missing", "invalid", "not found", "does not exist")) {
                return "권한 거부가 아닌 사용자 조회 단계 응답 확인 - 사용자 계열 RFC 호출 단계 진입 가능";
            }
        }

        if (ProbeResultType.CALL_REACHED_BACKEND.name().equals(probeResult)) {
            return "RFC 권한 거부 없이 백엔드 호출 단계 도달";
        }

        if (ProbeResultType.COMM_OR_SYSTEM_ERROR.name().equals(probeResult)) {
            return "통신/시스템 오류로 인해 권한 여부 단정 어려움";
        }

        if ("Y".equals(repoVisible)) {
            return "메타데이터 노출은 확인되나 호출 가능성은 추가 확인 필요";
        }

        return "확인 필요";
    }

    private static void loadExternalTargets(LinkedHashMap<String, LinkedHashSet<String>> map, String fileName) {
        File f = new File(fileName);
        if (!f.exists()) {
            System.out.println("[i] 추가 RFC 목록 파일 없음: " + fileName);
            return;
        }

        int added = 0;

        try (BufferedReader br = new BufferedReader(
                new InputStreamReader(new FileInputStream(f), StandardCharsets.UTF_8))) {

            String line;
            while ((line = br.readLine()) != null) {
                String raw = line.trim();
                if (raw.isEmpty() || raw.startsWith("#")) continue;

                String category = "EXTERNAL_CUSTOM";
                String rfcName = raw;

                if (raw.contains("::")) {
                    String[] parts = raw.split("::", 2);
                    category = parts[0].trim().isEmpty() ? "EXTERNAL_CUSTOM" : parts[0].trim();
                    rfcName = parts[1].trim();
                }

                if (rfcName.isEmpty()) continue;

                map.computeIfAbsent(category, k -> new LinkedHashSet<>());
                if (map.get(category).add(rfcName)) added++;
            }

            System.out.println("[+] 외부 RFC 목록 로드 완료: " + fileName + " / added=" + added);

        } catch (Exception e) {
            System.out.println("[!] 외부 RFC 목록 로드 실패: " + sanitize(e.getMessage()));
        }
    }

    private static String summarizeParams(JCoParameterList list) {
        if (list == null) return "-";

        try {
            JCoListMetaData meta = list.getMetaData();
            if (meta == null || meta.getFieldCount() == 0) return "-";

            StringBuilder sb = new StringBuilder();
            int count = meta.getFieldCount();
            int limit = Math.min(count, PARAM_PREVIEW_LIMIT);

            for (int i = 0; i < limit; i++) {
                if (i > 0) sb.append(" | ");

                String name = safe(meta.getName(i));
                String type = "?";
                String len = "?";

                try { type = meta.getTypeAsString(i); } catch (Exception ignore) {}
                try { len = String.valueOf(meta.getLength(i)); } catch (Exception ignore) {}

                sb.append(name).append("(").append(type).append(",len=").append(len).append(")");
            }

            if (count > limit) {
                sb.append(" | ... total=").append(count);
            }

            return sb.toString();

        } catch (Exception e) {
            return "param-read-error";
        }
    }

    private static void addCategory(LinkedHashMap<String, LinkedHashSet<String>> map, String category, String... rfcs) {
        map.putIfAbsent(category, new LinkedHashSet<>());
        for (String rfc : rfcs) {
            if (rfc != null && !rfc.trim().isEmpty()) {
                map.get(category).add(rfc.trim());
            }
        }
    }

    private static void printHighlighted(String rfcName, String repoVisible, String probeAttempted, String probeResult,
                                         String highlight, String interpretation, String message) {
        if ("HIGH_VALUE_CALLABLE".equals(highlight)) {
            System.out.println("================================================================");
            System.out.println("[!!! HIGH VALUE CALLABLE !!!] " + rfcName);
            System.out.println(" Repo          : " + repoVisible);
            System.out.println(" ProbeAttempt  : " + probeAttempted);
            System.out.println(" ProbeResult   : " + probeResult);
            System.out.println(" Highlight     : " + highlight);
            System.out.println(" Interpretation: " + interpretation);
            System.out.println(" Message       : " + message);
            System.out.println("================================================================");
            return;
        }

        if ("CALLABLE".equals(highlight)) {
            System.out.println("[+] " + pad(rfcName, 32) + " -> " + highlight + " / " + interpretation);
            return;
        }

        if ("EXPOSED_BUT_DENIED".equals(highlight)) {
            System.out.println("[-] " + pad(rfcName, 32) + " -> " + highlight + " / " + interpretation);
            return;
        }

        System.out.println("[ ] " + pad(rfcName, 32) + " -> " + highlight + " / " + interpretation);
    }

    private static void printLine(String rfcName, String highlight, String interpretation) {
        System.out.println("[ ] " + pad(rfcName, 32) + " -> " + highlight + " / " + interpretation);
    }

    private static boolean containsAny(String s, String... keywords) {
        if (s == null) return false;
        for (String k : keywords) {
            if (s.contains(k)) return true;
        }
        return false;
    }

    private static String pad(String s, int len) {
        if (s == null) return "";
        if (s.length() >= len) return s;
        StringBuilder sb = new StringBuilder(s);
        while (sb.length() < len) sb.append(' ');
        return sb.toString();
    }

    private static void writeCsv(String fileName, List<String[]> rows) throws IOException {
        try (BufferedWriter bw = new BufferedWriter(
                new OutputStreamWriter(new FileOutputStream(fileName), StandardCharsets.UTF_8))) {

            for (String[] row : rows) {
                StringBuilder line = new StringBuilder();
                for (int i = 0; i < row.length; i++) {
                    if (i > 0) line.append(",");
                    line.append(csvEscape(row[i]));
                }
                bw.write(line.toString());
                bw.newLine();
            }
        }
    }

    private static String csvEscape(String s) {
        if (s == null) return "\"\"";
        return "\"" + s.replace("\"", "\"\"") + "\"";
    }

    private static String sanitize(String s) {
        if (s == null) return "";
        return s.replaceAll("[\\r\\n]+", " ").trim();
    }

    private static String safe(String s) {
        return s == null ? "" : s;
    }

    private static void createDestinationFile(String name, Properties props) throws Exception {
        File destFile = new File(name + ".jcoDestination");
        try (FileOutputStream fos = new FileOutputStream(destFile)) {
            props.store(fos, "SAP Callable Evidence Mega Audit Destination");
        }
    }
